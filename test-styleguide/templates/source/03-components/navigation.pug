//- Demonstrates Pug `extends` + named blocks. The base layout lives in
//- templates/layouts/_layout.pug.
extends ../../layouts/_layout

block toolbar
  | Navigation component

block content
  nav.c-nav(aria-label="Main navigation")
    a.c-nav__brand(href="#") Acme
    ul.c-nav__list
      li
        a.c-nav__link.c-nav__link--active(href="#" aria-current="page") Home
      li
        a.c-nav__link(href="#") Products
      li
        a.c-nav__link(href="#") About
      li
        a.c-nav__link(href="#") Contact
