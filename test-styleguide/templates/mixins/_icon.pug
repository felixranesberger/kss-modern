//- Renders an inline SVG icon by name from the demo icon set.
//- Included by other mixins to exercise transitive Pug include tracking.
mixin icon(name)
  - const common = { xmlns: 'http://www.w3.org/2000/svg', width: 24, height: 24, viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', 'stroke-width': 2, 'stroke-linecap': 'round', 'stroke-linejoin': 'round', 'aria-hidden': 'true' }
  if name === 'arrow-right'
    svg.c-icon(class=attributes.class)&attributes(common)
      path(d="M5 12h14")
      path(d="m12 5 7 7-7 7")
  else if name === 'check'
    svg.c-icon(class=attributes.class)&attributes(common)
      path(d="M20 6 9 17l-5-5")
  else if name === 'search'
    svg.c-icon(class=attributes.class)&attributes(common)
      circle(cx="11" cy="11" r="8")
      path(d="m21 21-4.3-4.3")
  else if name === 'external-link'
    svg.c-icon(class=attributes.class)&attributes(common)
      path(d="M15 3h6v6")
      path(d="M10 14 21 3")
      path(d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6")
  else if name === 'info'
    svg.c-icon(class=attributes.class)&attributes(common)
      circle(cx="12" cy="12" r="10")
      path(d="M12 16v-4")
      path(d="M12 8h.01")
  else if name === 'chevron-down'
    svg.c-icon(class=attributes.class)&attributes(common)
      path(d="m6 9 6 6 6-6")
  else
    span.c-icon(aria-hidden="true")= '?'
