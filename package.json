{
  "name": "kss-modern",
  "type": "module",
  "version": "0.0.48",
  "description": "Modern KSS compatible styleguide generator",
  "keywords": [
    "kss",
    "kss-node",
    "styleguide",
    "living-styleguide",
    "design-system",
    "component-library",
    "pattern-library",
    "documentation",
    "sass",
    "pug",
    "static-site-generator",
    "accessibility",
    "a11y",
    "figma",
    "dark-mode"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixranesberger/kss-modern.git"
  },
  "bugs": "https://github.com/felixranesberger/kss-modern/issues",
  "main": "./dist/node/lib/index.mjs",
  "types": "./dist/node/lib/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && unbuild",
    "dev": "bun run build && deno run --unstable-sloppy-imports --allow-all index.ts",
    "lint": "eslint {lib,client}",
    "release": "bun run lint && bumpp",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "bun run build && playwright test"
  },
  "dependencies": {
    "@antfu/utils": "^9.3.0",
    "@biomejs/js-api": "^4.0.0",
    "@biomejs/wasm-nodejs": "^2.4.15",
    "@shikijs/markdown-it": "^4.1.0",
    "chokidar": "^5.0.0",
    "fs-extra": "^11.3.5",
    "markdown-it-async": "^2.2.0",
    "pug": "^3.0.4",
    "shiki": "^4.1.0",
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/fs-extra": "^11.0.4",
    "@vitest/coverage-v8": "^4.1.7",
    "axe-core": "^4.11.4",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "html-validate": "^11.4.0",
    "jsdom": "^29.1.1",
    "keyux": "^0.11.5",
    "motion": "^12.40.0",
    "unbuild": "^3.6.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
